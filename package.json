{
  "name": "solarmart-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:user": "pnpm --filter @solarmart/user-web dev",
    "dev:admin": "pnpm --filter @solarmart/admin-web dev",
    "build": "pnpm -r build",
    "build:user": "pnpm --filter @solarmart/user-web build",
    "build:admin": "pnpm --filter @solarmart/admin-web build"
  }
}
